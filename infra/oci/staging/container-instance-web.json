{
  "displayName": "codeforge-web-staging",
  "compartmentId": "${COMPARTMENT_ID}",
  "availabilityDomain": "${AVAILABILITY_DOMAIN}",
  "shape": "CI.Standard.E4.Flex",
  "shapeConfig": {
    "ocpus": 1,
    "memoryInGBs": 2
  },
  "containerRestartPolicy": "ALWAYS",
  "vnics": [{
    "displayName": "codeforge-web-staging-vnic",
    "subnetId": "${PRIVATE_SUBNET_ID}",
    "isPublicIp": false,
    "nsgIds": ["${WEB_NSG_ID}"]
  }],
  "containers": [{
    "displayName": "codeforge-web",
    "imageUrl": "${OCIR_REGISTRY}/${OCIR_REPOSITORY_WEB}:${IMAGE_TAG}",
    "isResourcePrincipal": false,
    "resourceConfig": {
      "ocpus": 1,
      "memoryInGBs": 2
    },
    "environmentVariables": {
      "NODE_ENV": "production",
      "NEXT_PUBLIC_API_BASE": "${API_PUBLIC_URL}"
    },
    "ports": [{
      "port": 3000,
      "protocol": "TCP"
    }]
  }]
}
