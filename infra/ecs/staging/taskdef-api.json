{
  "family": "codeforge-api-staging-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::111111111111:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::111111111111:role/codeforgeApiTaskRoleStaging",
  "containerDefinitions": [
    {
      "name": "codeforge-api",
      "image": "111111111111.dkr.ecr.ap-south-1.amazonaws.com/codeforge-api:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8000,
          "hostPort": 8000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "OTEL_SERVICE_NAME",
          "value": "codeforge-api"
        },
        {
          "name": "OTEL_ENVIRONMENT",
          "value": "staging"
        },
        {
          "name": "OPENAI_BASE_URL",
          "value": "https://api.openai.com/v1"
        },
        {
          "name": "CODEFORGE_SYNTHESIS_MODEL",
          "value": "gpt-4o-mini"
        }
      ],
      "secrets": [
        {
          "name": "DATABASE_URL",
          "valueFrom": "arn:aws:ssm:ap-south-1:111111111111:parameter/codeforge/staging/DATABASE_URL"
        },
        {
          "name": "SUPABASE_JWT_SECRET",
          "valueFrom": "arn:aws:ssm:ap-south-1:111111111111:parameter/codeforge/staging/SUPABASE_JWT_SECRET"
        },
        {
          "name": "RAZORPAY_KEY_ID",
          "valueFrom": "arn:aws:ssm:ap-south-1:111111111111:parameter/codeforge/staging/RAZORPAY_KEY_ID"
        },
        {
          "name": "RAZORPAY_KEY_SECRET",
          "valueFrom": "arn:aws:ssm:ap-south-1:111111111111:parameter/codeforge/staging/RAZORPAY_KEY_SECRET"
        },
        {
          "name": "OPENAI_API_KEY",
          "valueFrom": "arn:aws:ssm:ap-south-1:111111111111:parameter/codeforge/staging/OPENAI_API_KEY"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/codeforge-api-staging",
          "awslogs-region": "ap-south-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
