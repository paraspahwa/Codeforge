{
  "family": "codeforge-worker-staging-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "1024",
  "memory": "2048",
  "executionRoleArn": "arn:aws:iam::111111111111:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::111111111111:role/codeforgeApiTaskRoleStaging",
  "volumes": [
    {
      "name": "codeforge-workspaces",
      "efsVolumeConfiguration": {
        "fileSystemId": "fs-PLACEHOLDER",
        "rootDirectory": "/codeforge",
        "transitEncryption": "ENABLED"
      }
    }
  ],
  "containerDefinitions": [
    {
      "name": "codeforge-worker",
      "image": "111111111111.dkr.ecr.ap-south-1.amazonaws.com/codeforge-worker:latest",
      "essential": true,
      "command": [
        "celery",
        "-A",
        "app.celery_worker:celery_app",
        "worker",
        "--beat",
        "--loglevel=info"
      ],
      "environment": [
        {
          "name": "CODEFORGE_ENV",
          "value": "production"
        },
        {
          "name": "CODEFORGE_COWORK_SCHEDULER_ENABLED",
          "value": "false"
        },
        {
          "name": "OTEL_SERVICE_NAME",
          "value": "codeforge-worker"
        },
        {
          "name": "OTEL_ENVIRONMENT",
          "value": "staging"
        },
        {
          "name": "CODEFORGE_DISABLE_PLAYWRIGHT",
          "value": "false"
        },
        {
          "name": "PLAYWRIGHT_BROWSERS_PATH",
          "value": "/ms-playwright"
        },
        {
          "name": "CODEFORGE_WORKSPACES_CONTAINER_PREFIX",
          "value": "/workspaces"
        },
        {
          "name": "CODEFORGE_WORKSPACES_HOST_PREFIX",
          "value": "/workspaces"
        }
      ],
      "mountPoints": [
        {
          "sourceVolume": "codeforge-workspaces",
          "containerPath": "/workspaces",
          "readOnly": false
        }
      ],
      "secrets": [
        {
          "name": "DATABASE_URL",
          "valueFrom": "arn:aws:ssm:ap-south-1:111111111111:parameter/codeforge/staging/DATABASE_URL"
        },
        {
          "name": "REDIS_URL",
          "valueFrom": "arn:aws:ssm:ap-south-1:111111111111:parameter/codeforge/staging/REDIS_URL"
        },
        {
          "name": "CELERY_BROKER_URL",
          "valueFrom": "arn:aws:ssm:ap-south-1:111111111111:parameter/codeforge/staging/CELERY_BROKER_URL"
        },
        {
          "name": "CELERY_RESULT_BACKEND",
          "valueFrom": "arn:aws:ssm:ap-south-1:111111111111:parameter/codeforge/staging/CELERY_RESULT_BACKEND"
        },
        {
          "name": "QDRANT_URL",
          "valueFrom": "arn:aws:ssm:ap-south-1:111111111111:parameter/codeforge/staging/QDRANT_URL"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/codeforge-worker-staging",
          "awslogs-region": "ap-south-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
