{
  "family": "codeforge-qdrant-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "1024",
  "memory": "2048",
  "executionRoleArn": "arn:aws:iam::111111111111:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::111111111111:role/codeforgeApiTaskRoleProd",
  "containerDefinitions": [
    {
      "name": "codeforge-qdrant",
      "image": "qdrant/qdrant:v1.13.1",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 6333,
          "hostPort": 6333,
          "protocol": "tcp"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/codeforge-qdrant-prod",
          "awslogs-region": "ap-south-1",
          "awslogs-stream-prefix": "qdrant"
        }
      }
    }
  ]
}
