{
  "family": "codeforge-api-production-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "1024",
  "memory": "2048",
  "executionRoleArn": "arn:aws:iam::111111111111:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::111111111111:role/codeforgeApiTaskRoleProd",
  "containerDefinitions": [
    {
      "name": "codeforge-api",
      "image": "111111111111.dkr.ecr.ap-south-1.amazonaws.com/codeforge-api:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8000,
          "hostPort": 8000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "OTEL_SERVICE_NAME",
          "value": "codeforge-api"
        },
        {
          "name": "OTEL_ENVIRONMENT",
          "value": "production"
        },
        {
          "name": "CODEFORGE_ENV",
          "value": "production"
        },
        {
          "name": "CODEFORGE_COWORK_SCHEDULER_ENABLED",
          "value": "false"
        },
        {
          "name": "OPENAI_BASE_URL",
          "value": "https://api.openai.com/v1"
        },
        {
          "name": "CODEFORGE_SYNTHESIS_MODEL",
          "value": "gpt-4o-mini"
        },
        {
          "name": "CODEFORGE_OIDC_ENABLED",
          "value": "true"
        },
        {
          "name": "CODEFORGE_OIDC_TRUST_SUBJECT",
          "value": "false"
        },
        {
          "name": "CODEFORGE_OIDC_SCOPES",
          "value": "openid profile email"
        },
        {
          "name": "CODEFORGE_WEB_BASE_URL",
          "value": "https://app.codeforge.example"
        }
      ],
      "secrets": [
        {
          "name": "DATABASE_URL",
          "valueFrom": "arn:aws:ssm:ap-south-1:111111111111:parameter/codeforge/prod/DATABASE_URL"
        },
        {
          "name": "SUPABASE_JWT_SECRET",
          "valueFrom": "arn:aws:ssm:ap-south-1:111111111111:parameter/codeforge/prod/SUPABASE_JWT_SECRET"
        },
        {
          "name": "RAZORPAY_KEY_ID",
          "valueFrom": "arn:aws:ssm:ap-south-1:111111111111:parameter/codeforge/prod/RAZORPAY_KEY_ID"
        },
        {
          "name": "RAZORPAY_KEY_SECRET",
          "valueFrom": "arn:aws:ssm:ap-south-1:111111111111:parameter/codeforge/prod/RAZORPAY_KEY_SECRET"
        },
        {
          "name": "OPENAI_API_KEY",
          "valueFrom": "arn:aws:ssm:ap-south-1:111111111111:parameter/codeforge/prod/OPENAI_API_KEY"
        },
        {
          "name": "REDIS_URL",
          "valueFrom": "arn:aws:ssm:ap-south-1:111111111111:parameter/codeforge/prod/REDIS_URL"
        },
        {
          "name": "CELERY_BROKER_URL",
          "valueFrom": "arn:aws:ssm:ap-south-1:111111111111:parameter/codeforge/prod/CELERY_BROKER_URL"
        },
        {
          "name": "CELERY_RESULT_BACKEND",
          "valueFrom": "arn:aws:ssm:ap-south-1:111111111111:parameter/codeforge/prod/CELERY_RESULT_BACKEND"
        },
        {
          "name": "QDRANT_URL",
          "valueFrom": "arn:aws:ssm:ap-south-1:111111111111:parameter/codeforge/prod/QDRANT_URL"
        },
        {
          "name": "CODEFORGE_OIDC_ISSUER",
          "valueFrom": "arn:aws:ssm:ap-south-1:111111111111:parameter/codeforge/prod/CODEFORGE_OIDC_ISSUER"
        },
        {
          "name": "CODEFORGE_OIDC_AUDIENCE",
          "valueFrom": "arn:aws:ssm:ap-south-1:111111111111:parameter/codeforge/prod/CODEFORGE_OIDC_AUDIENCE"
        },
        {
          "name": "CODEFORGE_OIDC_JWKS_URI",
          "valueFrom": "arn:aws:ssm:ap-south-1:111111111111:parameter/codeforge/prod/CODEFORGE_OIDC_JWKS_URI"
        },
        {
          "name": "CODEFORGE_OIDC_CLIENT_ID",
          "valueFrom": "arn:aws:ssm:ap-south-1:111111111111:parameter/codeforge/prod/CODEFORGE_OIDC_CLIENT_ID"
        },
        {
          "name": "CODEFORGE_OIDC_CLIENT_SECRET",
          "valueFrom": "arn:aws:ssm:ap-south-1:111111111111:parameter/codeforge/prod/CODEFORGE_OIDC_CLIENT_SECRET"
        },
        {
          "name": "CODEFORGE_OIDC_REDIRECT_URI",
          "valueFrom": "arn:aws:ssm:ap-south-1:111111111111:parameter/codeforge/prod/CODEFORGE_OIDC_REDIRECT_URI"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/codeforge-api-prod",
          "awslogs-region": "ap-south-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
