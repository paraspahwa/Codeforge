# CodeForge production environment template
# Copy to .env on your VPS or secret manager, then fill every CHANGE_ME value.
# Guide: docs/PRODUCTION_DEPLOYMENT_CHECKLIST.md

# --- Core ---
CODEFORGE_ENV=production
CODEFORGE_ALLOW_DEV_LOGIN=false

# --- Database (Supabase pooler or compose Postgres) ---
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DATABASE_URL=postgresql://postgres.CHANGE_ME:CHANGE_ME@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?sslmode=require

# --- Auth: Supabase JWT (when OIDC disabled) ---
SUPABASE_JWT_SECRET=CHANGE_ME_SUPABASE_JWT_SECRET

# --- Auth: OIDC SSO (recommended for public prod; set CODEFORGE_OIDC_ENABLED=true) ---
CODEFORGE_OIDC_ENABLED=false
CODEFORGE_OIDC_ISSUER=https://your-idp.example.com
CODEFORGE_OIDC_AUDIENCE=codeforge-api
CODEFORGE_OIDC_JWKS_URI=
CODEFORGE_OIDC_TRUST_SUBJECT=false
CODEFORGE_OIDC_CLIENT_ID=
CODEFORGE_OIDC_CLIENT_SECRET=
CODEFORGE_OIDC_REDIRECT_URI=https://app.yourdomain.com/auth/callback
CODEFORGE_OIDC_SCOPES=openid profile email

# --- Public URLs (must match Cloudflare DNS) ---
CODEFORGE_WEB_BASE_URL=https://app.yourdomain.com
CODEFORGE_PUBLIC_API_BASE=https://api.yourdomain.com
CODEFORGE_CORS_ORIGINS=https://app.yourdomain.com
CODEFORGE_API_BASE_URL=https://api.yourdomain.com

# Web build-time only (Vercel / docker build arg) ---
NEXT_PUBLIC_API_BASE=https://api.yourdomain.com
VITE_CODEFORGE_API_BASE_URL=https://api.yourdomain.com
VITE_CODEFORGE_WEB_BASE_URL=https://app.yourdomain.com

# --- Queue (Upstash or compose redis) ---
REDIS_URL=redis://default:CHANGE_ME@CHANGE_ME.upstash.io:6379/0
CELERY_BROKER_URL=redis://default:CHANGE_ME@CHANGE_ME.upstash.io:6379/1
CELERY_RESULT_BACKEND=redis://default:CHANGE_ME@CHANGE_ME.upstash.io:6379/1

# --- Vector memory (Qdrant Cloud or compose) ---
QDRANT_URL=https://CHANGE_ME.cloud.qdrant.io:6333

# --- Billing (Razorpay — use test keys first) ---
RAZORPAY_KEY_ID=rzp_test_CHANGE_ME
RAZORPAY_KEY_SECRET=CHANGE_ME

# --- LLM: OpenAI (required for real chat, embeddings, scrape, vision) ---
OPENAI_API_KEY=sk-CHANGE_ME
OPENAI_BASE_URL=https://api.openai.com/v1
CODEFORGE_SYNTHESIS_MODEL=gpt-4o-mini
CODEFORGE_EMBEDDING_MODEL=text-embedding-3-small
CODEFORGE_VISION_MODEL=gpt-4o-mini
CODEFORGE_SYNTHESIS_PROVIDER=openai

# --- LLM: Azure OpenAI (production CI synthesis gate) ---
AZURE_OPENAI_ENDPOINT=https://CHANGE_ME.openai.azure.com
AZURE_OPENAI_API_KEY=CHANGE_ME
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-10-21

# --- LLM: LiteLLM routing (optional — DeepSeek / Claude tiers) ---
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=
CODEFORGE_DEFAULT_MODEL=deepseek-v4-flash
CODEFORGE_COMPLEX_MODEL=deepseek-v4-pro
CODEFORGE_FALLBACK_MODEL=claude-sonnet-4.6
CODEFORGE_FRONTIER_MODEL=claude-opus-4.1

# --- Optional: Supermemory BYOK ---
SUPERMEMORY_CC_API_KEY=
SUPERMEMORY_API_URL=https://api.supermemory.ai

# --- Cowork / scrape ---
CODEFORGE_SCRAPE_ENABLED=true
CODEFORGE_SCRAPE_MODEL=
CODEFORGE_SCRAPE_VERBOSE=false
CODEFORGE_COWORK_SCHEDULER_ENABLED=false
CODEFORGE_COWORK_TICK_SECONDS=2
CODEFORGE_DISABLE_PLAYWRIGHT=false

# --- RTK shell compression ---
CODEFORGE_RTK_ENABLED=true
CODEFORGE_RTK_DEBUG=false

# --- Hermes Agent sidecar (optional; install hermes on API host) ---
CODEFORGE_HERMES_ENABLED=false
CODEFORGE_HERMES_SIMULATE=false
CODEFORGE_HERMES_BINARY=
CODEFORGE_HERMES_EXTRA_ARGS=
CODEFORGE_HERMES_PROFILE_PREFIX=codeforge
HERMES_HOME=

# --- Workspaces (git/shell/cowork file paths) ---
CODEFORGE_HOST_WORKSPACES=./workspaces
CODEFORGE_WORKSPACES_HOST_PREFIX=
CODEFORGE_WORKSPACES_CONTAINER_PREFIX=/workspaces

# --- Usage limits ---
CODEFORGE_FREE_REQUEST_LIMIT=100
CODEFORGE_WORKSPACE_RATE_LIMIT=60

# --- Observability (optional) ---
OTEL_SERVICE_NAME=codeforge-api
OTEL_ENVIRONMENT=production
OTEL_EXPORTER_OTLP_ENDPOINT=
