# CodeForge Production Environment Template
# Copy this file to .env, then fill every value below.
# Each section tells you exactly where to get each value.

###############################################################################
# STEP 1: CORE SETTINGS (nothing to get — just set these as-is)
###############################################################################
CODEFORGE_ENV=production
# Keep dev-login disabled in production. Enable only if you need the quick
# "Continue" button during initial setup on a private staging server.
CODEFORGE_ALLOW_DEV_LOGIN=false

###############################################################################
# STEP 2: DATABASE — Sign up at https://supabase.com
###############################################################################
# How to get Supabase credentials:
#   1. Go to https://supabase.com → "New project" → pick a name & secure password
#   2. Wait ~2 min for provisioning
#   3. Go to Project Settings → Database → Connection string (Pooler)
#   4. Copy the URI — it looks like:
#      postgresql://postgres.xxxxx:password@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?sslmode=require
#   5. Replace both "CHANGE_ME" values below with your actual project ref & password

POSTGRES_PASSWORD=CHANGE_ME — PUT YOUR SUPABASE DATABASE PASSWORD HERE
DATABASE_URL=postgresql://postgres.CHANGE_ME:CHANGE_ME@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?sslmode=require
#               ▲ project ref ▲ password — replace both

###############################################################################
# STEP 3: AUTH — Pick ONE path (A or B). Path A is simpler to start.
###############################################################################

# ── PATH A: Supabase JWT (easier, use this first) ──────────────────────────
# How to get your Supabase JWT Secret:
#   1. In Supabase Dashboard → Project Settings → API
#   2. Find the "JWT Secret" field (it's a long hex string, ~40 chars)
#   3. Copy it and paste below

SUPABASE_JWT_SECRET=CHANGE_ME — PASTE YOUR SUPABASE JWT SECRET HERE

# ── PATH B: OIDC SSO (Google / Microsoft / any OpenID provider) ────────────
# Skip this section unless you want production SSO. Leave as-is for now.
CODEFORGE_OIDC_ENABLED=false
# If you change to true later:
# CODEFORGE_OIDC_ISSUER — from your IdP (e.g. https://accounts.google.com)
# CODEFORGE_OIDC_CLIENT_ID — from your IdP app registration
# CODEFORGE_OIDC_CLIENT_SECRET — from your IdP app registration
CODEFORGE_OIDC_ISSUER=https://your-idp.example.com
CODEFORGE_OIDC_AUDIENCE=codeforge-api
CODEFORGE_OIDC_JWKS_URI=
CODEFORGE_OIDC_TRUST_SUBJECT=false
CODEFORGE_OIDC_CLIENT_ID=
CODEFORGE_OIDC_CLIENT_SECRET=
CODEFORGE_OIDC_REDIRECT_URI=https://app.yourdomain.com/auth/callback
CODEFORGE_OIDC_SCOPES=openid profile email

###############################################################################
# STEP 4: PUBLIC URLs — Replace with YOUR domain
###############################################################################
# You need a domain (buy from any registrar, e.g. GoDaddy, Namecheap, Cloudflare).
# Point DNS to your server (see Step 7 for Oracle Cloud IP).
#
# Example: if your domain is "myapp.com":
#   CODEFORGE_WEB_BASE_URL=https://app.myapp.com
#   CODEFORGE_PUBLIC_API_BASE=https://api.myapp.com
#   CODEFORGE_CORS_ORIGINS=https://app.myapp.com
#   NEXT_PUBLIC_API_BASE=https://api.myapp.com
#   (These DNS records are created in Cloudflare — see Step 7)

CODEFORGE_WEB_BASE_URL=https://app.yourdomain.com
CODEFORGE_PUBLIC_API_BASE=https://api.yourdomain.com
CODEFORGE_CORS_ORIGINS=https://app.yourdomain.com
CODEFORGE_API_BASE_URL=https://api.yourdomain.com
NEXT_PUBLIC_API_BASE=https://api.yourdomain.com
VITE_CODEFORGE_API_BASE_URL=https://api.yourdomain.com
VITE_CODEFORGE_WEB_BASE_URL=https://app.yourdomain.com

###############################################################################
# STEP 5: REDIS (queue for Celery workers) — Sign up at https://upstash.com
###############################################################################
# How to get Upstash Redis credentials:
#   1. Go to https://upstash.com → Sign up (free plan: 10MB, enough to start)
#   2. Click "Create Database" → name it "codeforge" → select nearest region
#   3. Once created, go to the database detail page
#   4. Copy the "REST URL" or "Redis URL" — it starts with "redis://default:..."
#   5. Paste it below replacing both CHANGE_ME values
#   6. Add /0, /1 at the end for different logical databases (broker vs result)

REDIS_URL=redis://default:CHANGE_ME@CHANGE_ME.upstash.io:6379/0
#                      ▲ password  ▲endpoint — replace both
CELERY_BROKER_URL=redis://default:CHANGE_ME@CHANGE_ME.upstash.io:6379/1
# Same URL but with /1 at the end (different Redis database index)
CELERY_RESULT_BACKEND=redis://default:CHANGE_ME@CHANGE_ME.upstash.io:6379/1
# Same as broker — same URL, same /1

###############################################################################
# STEP 6: VECTOR DATABASE (Qdrant) — Sign up at https://cloud.qdrant.io
###############################################################################
# How to get Qdrant Cloud URL:
#   1. Go to https://cloud.qdrant.io → "Start free" (free 1GB cluster)
#   2. Create a cluster → name it "codeforge" → pick nearest region
#   3. Wait 1-2 min for provisioning
#   4. Go to the cluster detail page → copy the "Cluster URL"
#   5. It looks like: https://xxxxx-xxxxx.cloud.qdrant.io:6333
#   6. Paste below replacing CHANGE_ME

QDRANT_URL=https://CHANGE_ME.cloud.qdrant.io:6333

###############################################################################
# STEP 7: BILLING (Razorpay) — Sign up at https://razorpay.com
###############################################################################
# How to get Razorpay test keys (use test mode first):
#   1. Go to https://dashboard.razorpay.com → Sign up
#   2. In Dashboard → Settings → API Keys → "Generate Key"
#   3. You'll get:
#      - Key ID: starts with "rzp_test_..."
#      - Key Secret: long alphanumeric string
#   4. Paste them below
#   5. When ready for real money, switch to live keys from the same page
#      Live keys start with "rzp_live_..."

RAZORPAY_KEY_ID=rzp_test_CHANGE_ME
RAZORPAY_KEY_SECRET=CHANGE_ME

###############################################################################
# STEP 8: LLM PROVIDERS — Sign up at https://platform.openai.com
###############################################################################
# How to get OpenAI API key:
#   1. Go to https://platform.openai.com → Sign up / Log in
#   2. Go to https://platform.openai.com/api-keys → "Create new secret key"
#   3. Copy the key (starts with "sk-...")
#   4. Add at least $5 credit in Billing → Payment methods
#   5. Paste below

OPENAI_API_KEY=sk-CHANGE_ME — PASTE YOUR OPENAI API KEY HERE
OPENAI_BASE_URL=https://api.openai.com/v1
CODEFORGE_SYNTHESIS_MODEL=gpt-4o-mini
CODEFORGE_EMBEDDING_MODEL=text-embedding-3-small
CODEFORGE_VISION_MODEL=gpt-4o-mini
CODEFORGE_SYNTHESIS_PROVIDER=openai

# ── Optional: Azure OpenAI (used as production CI gate) ────────────────────
# Only needed if you're using Azure for synthesis. Skip if not.
# Get these from Azure Portal → Azure OpenAI → Deployments
AZURE_OPENAI_ENDPOINT=https://CHANGE_ME.openai.azure.com
AZURE_OPENAI_API_KEY=CHANGE_ME
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-10-21

# ── Optional: DeepSeek / Anthropic (LiteLLM routing tiers) ─────────────────
# DeepSeek: https://platform.deepseek.com/api_keys (free trial available)
# Anthropic: https://console.anthropic.com → API Keys
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=
CODEFORGE_DEFAULT_MODEL=deepseek-v4-flash
CODEFORGE_COMPLEX_MODEL=deepseek-v4-pro
CODEFORGE_FALLBACK_MODEL=claude-sonnet-4.6
CODEFORGE_FRONTIER_MODEL=claude-opus-4.1

###############################################################################
# STEP 9: OPTIONAL FEATURES (skip these for MVP)
###############################################################################

# Supermemory — long-term memory via https://supermemory.ai
SUPERMEMORY_CC_API_KEY=
SUPERMEMORY_API_URL=https://api.supermemory.ai

# Cowork automation & web scraping
CODEFORGE_SCRAPE_ENABLED=true
CODEFORGE_SCRAPE_MODEL=
CODEFORGE_SCRAPE_VERBOSE=false
CODEFORGE_COWORK_SCHEDULER_ENABLED=false
CODEFORGE_COWORK_TICK_SECONDS=2
# Disable Playwright if your server has limited RAM (<2GB)
CODEFORGE_DISABLE_PLAYWRIGHT=false

# Shell output compression via RTK (https://github.com/rtk-ai/rtk)
# Install rtk binary on the server for this to work
CODEFORGE_RTK_ENABLED=true
CODEFORGE_RTK_DEBUG=false

# Hermes Agent sidecar (https://github.com/NousResearch/hermes-agent)
# Only if you run the Hermes agent binary alongside the API
CODEFORGE_HERMES_ENABLED=false
CODEFORGE_HERMES_SIMULATE=false
CODEFORGE_HERMES_BINARY=
CODEFORGE_HERMES_EXTRA_ARGS=
CODEFORGE_HERMES_PROFILE_PREFIX=codeforge
HERMES_HOME=

# Workspace directories for git/shell file operations
CODEFORGE_HOST_WORKSPACES=./workspaces
CODEFORGE_WORKSPACES_HOST_PREFIX=
CODEFORGE_WORKSPACES_CONTAINER_PREFIX=/workspaces

# Rate limits
CODEFORGE_FREE_REQUEST_LIMIT=100
CODEFORGE_WORKSPACE_RATE_LIMIT=60

# Observability with OpenTelemetry (optional)
# Set OTEL_EXPORTER_OTLP_ENDPOINT if you have an OTLP collector
OTEL_SERVICE_NAME=codeforge-api
OTEL_ENVIRONMENT=production
OTEL_EXPORTER_OTLP_ENDPOINT=

###############################################################################
# STEP 10: DEPLOY ON ORACLE CLOUD INFRASTRUCTURE
#
# Option A — Single VM (simplest, cheapest): 
#   1. Create an OCI Always Free VM (VM.Standard.A1.Flex — 4 OCPU, 24 GB RAM)
#      at https://cloud.oracle.com → Compute → Instances → Create Instance
#      Choose Ubuntu 24.04, pick your SSH key
#   2. SSH into the VM, then run:
#        sudo apt update && sudo apt install docker.io docker-compose-v2 git -y
#        git clone https://github.com/paraspahwa/Codeforge.git
#        cd Codeforge
#        cp .env.production.template .env
#        nano .env   ← fill all the CHANGE_ME values above
#        docker compose -f docker-compose.prod.yml up -d --build
#   3. Open ports 3000 and 8000 in OCI Security List:
#      OCI Console → Networking → Security Lists → Add Ingress Rules
#      Source: 0.0.0.0/0, Port: 3000, Protocol: TCP
#      Source: 0.0.0.0/0, Port: 8000, Protocol: TCP
#   4. Get your VM's public IP from OCI Console → Compute → Instance details
#
# Option B — Managed (Container Instances + Load Balancer):
#   1. See docs/OCI_DEPLOYMENT_GUIDE.md for Terraform setup
#   2. Run deploy-oci.yml GitHub Action after setting up secrets
#
# Option C — DNS via Cloudflare (free):
#   1. Go to https://cloudflare.com → Add your domain
#   2. Create these DNS records:
#      Type: A, Name: app,  Content: <your VM public IP>, Proxy: ✅ orange cloud
#      Type: A, Name: api,  Content: <your VM public IP>, Proxy: ✅ orange cloud
#   3. Cloudflare proxy gives you free SSL/HTTPS automatically
#   4. Wait 5-10 min for DNS to propagate
#   5. Now your app is live at https://app.yourdomain.com
#      (Replace yourdomain.com with your actual domain from Step 4)
###############################################################################
