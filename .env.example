# Database
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://codeforge:change-me@localhost:5432/codeforge

# Auth
SUPABASE_JWT_SECRET=change-me
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
CODEFORGE_ENV=development
# Required for docker compose dev-login (Continue button) when CODEFORGE_ENV=production in containers
CODEFORGE_ALLOW_DEV_LOGIN=true
CODEFORGE_DEV_LOGIN_SECRET=local-dev-login-secret
CODEFORGE_OIDC_ENABLED=false
CODEFORGE_OIDC_ISSUER=https://your-idp.example.com
CODEFORGE_OIDC_AUDIENCE=codeforge-api
CODEFORGE_OIDC_JWKS_URI=
CODEFORGE_OIDC_TRUST_SUBJECT=false
CODEFORGE_OIDC_CLIENT_ID=
CODEFORGE_OIDC_CLIENT_SECRET=
CODEFORGE_OIDC_REDIRECT_URI=
CODEFORGE_OIDC_SCOPES=openid profile email
CODEFORGE_WEB_BASE_URL=http://localhost:8080

# API
CODEFORGE_API_BASE_URL=http://127.0.0.1:8000
CODEFORGE_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8080,http://127.0.0.1:8080
CODEFORGE_REPO_ROOT=

# Shell output compression (rtk — https://github.com/rtk-ai/rtk)
CODEFORGE_RTK_ENABLED=false
CODEFORGE_RTK_DEBUG=false
CODEFORGE_RTK_BINARY=

# Hermes Agent sidecar (https://github.com/NousResearch/hermes-agent)
CODEFORGE_HERMES_ENABLED=false
CODEFORGE_HERMES_SIMULATE=false
CODEFORGE_HERMES_BINARY=
CODEFORGE_HERMES_EXTRA_ARGS=
CODEFORGE_HERMES_PROFILE_PREFIX=codeforge
HERMES_HOME=

# Optional Supermemory BYOK (https://supermemory.ai/docs/integrations/claude-code)
SUPERMEMORY_CC_API_KEY=
SUPERMEMORY_API_URL=https://api.supermemory.ai

# ScrapeGraphAI Cowork extraction (https://github.com/ScrapeGraphAI/Scrapegraph-ai)
CODEFORGE_SCRAPE_ENABLED=true
CODEFORGE_SCRAPE_MODEL=
CODEFORGE_SCRAPE_VERBOSE=false

# Client defaults
CODEFORGE_USER_ID=dev-user
CODEFORGE_FREE_REQUEST_LIMIT=100
CODEFORGE_MODEL=deepseek-v4-flash
NEXT_PUBLIC_API_BASE=http://localhost:8000
VITE_CODEFORGE_API_BASE_URL=http://localhost:8000

# Billing (Razorpay)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Observability
OTEL_SERVICE_NAME=codeforge-api
OTEL_ENVIRONMENT=local
OTEL_EXPORTER_OTLP_ENDPOINT=

# Model providers
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
CODEFORGE_SYNTHESIS_MODEL=gpt-4o-mini
CODEFORGE_VISION_MODEL=gpt-4o-mini
CODEFORGE_WORKSPACE_RATE_LIMIT=60
CODEFORGE_DEFAULT_MODEL=deepseek-v4-flash
CODEFORGE_COMPLEX_MODEL=deepseek-v4-pro
CODEFORGE_FALLBACK_MODEL=claude-sonnet-4.6

# Cowork in-process scheduler on the API only (set false in production; Celery beat on the worker runs ticks)
CODEFORGE_COWORK_SCHEDULER_ENABLED=
CODEFORGE_COWORK_TICK_SECONDS=2

# Docker workspace mounts (map host project dirs to /workspaces in containers)
CODEFORGE_HOST_WORKSPACES=./workspaces
CODEFORGE_WORKSPACES_HOST_PREFIX=
CODEFORGE_WORKSPACES_CONTAINER_PREFIX=/workspaces
CODEFORGE_PUBLIC_API_BASE=http://localhost:8000

# Agent Reach server channels (see docs/AGENT_REACH.md)
CODEFORGE_AGENT_REACH_WEB=true
CODEFORGE_AGENT_REACH_YOUTUBE=true
CODEFORGE_AGENT_REACH_RSS=true
CODEFORGE_AGENT_REACH_GITHUB=true
CODEFORGE_AGENT_REACH_EXA=true
CODEFORGE_AGENT_REACH_BILIBILI=true
CODEFORGE_AGENT_REACH_FIRECRAWL=true
# Optional keys for semantic search and JS-heavy extraction
EXA_API_KEY=
FIRECRAWL_API_KEY=

# Infrastructure (production compose)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/1
QDRANT_URL=http://localhost:6333

# OCI Container Instance deployment (see docs/OCI_DEPLOYMENT_GUIDE.md)
# Secrets are stored in OCI Vault, not env vars. For local dev these are fine.
# Set in OCI Console / GitHub Actions secrets for production:
# - OCI_COMPARTMENT_ID, OCI_VAULT_ID, OCI_KEY_ID
# - OCIR_REGISTRY, OCIR_AUTH_TOKEN
# - OCI_PRIVATE_SUBNET_ID, OCI_AVAILABILITY_DOMAIN
