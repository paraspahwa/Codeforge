# Database
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://codeforge:change-me@localhost:5432/codeforge

# Auth
SUPABASE_JWT_SECRET=change-me
CODEFORGE_ENV=development

# API
CODEFORGE_API_BASE_URL=http://127.0.0.1:8000
CODEFORGE_CORS_ORIGINS=http://localhost:3000
CODEFORGE_REPO_ROOT=

# Client defaults
CODEFORGE_USER_ID=dev-user
CODEFORGE_FREE_REQUEST_LIMIT=100
CODEFORGE_MODEL=deepseek-v4-flash
NEXT_PUBLIC_API_BASE=http://localhost:8000
VITE_CODEFORGE_API_BASE_URL=http://localhost:8000

# Billing (Razorpay)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Observability
OTEL_SERVICE_NAME=codeforge-api
OTEL_ENVIRONMENT=local
OTEL_EXPORTER_OTLP_ENDPOINT=

# Model providers
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
CODEFORGE_SYNTHESIS_MODEL=gpt-4o-mini
CODEFORGE_DEFAULT_MODEL=deepseek-v4-flash
CODEFORGE_COMPLEX_MODEL=deepseek-v4-pro
CODEFORGE_FALLBACK_MODEL=claude-sonnet-4.6

# Docker workspace mounts (map host project dirs to /workspaces in containers)
CODEFORGE_HOST_WORKSPACES=./workspaces
CODEFORGE_WORKSPACES_HOST_PREFIX=
CODEFORGE_WORKSPACES_CONTAINER_PREFIX=/workspaces
CODEFORGE_PUBLIC_API_BASE=http://localhost:8000

# Infrastructure (production compose)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/1
QDRANT_URL=http://localhost:6333
