{
  "name": "codeforge",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm --workspace apps/web run dev",
    "build:web": "npm --workspace apps/web run build",
    "start:web": "npm --workspace apps/web run start",
    "lint:web": "npm --workspace apps/web run lint",
    "dev:desktop": "npm --workspace apps/desktop run dev",
    "build:desktop": "npm --workspace apps/desktop run build",
    "desktop:tauri": "npm --workspace apps/desktop run tauri",
    "dev:terminal": "npm --workspace apps/terminal run dev",
    "terminal": "npm --workspace apps/terminal run start",
    "check:vscode": "npm --workspace apps/vscode run check",
    "api:dev": "uvicorn app.main:app --reload --host 0.0.0.0 --port 8000 --app-dir services/api",
    "api:run": "uvicorn app.main:app --host 0.0.0.0 --port 8000 --app-dir services/api",
    "api:test": "cd services/api && pytest -q",
    "api:migrate": "cd services/api && alembic upgrade head"
  }
}
