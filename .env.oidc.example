# Copy to .env.oidc and run:
# python scripts/bootstrap_oidc_ssm.py --environment staging --env-file .env.oidc
# Production SSM path: /codeforge/prod/CODEFORGE_OIDC_* (bootstrap uses --environment production)

CODEFORGE_OIDC_ISSUER=https://your-idp.example.com
CODEFORGE_OIDC_AUDIENCE=codeforge-api
CODEFORGE_OIDC_JWKS_URI=https://your-idp.example.com/.well-known/jwks.json
CODEFORGE_OIDC_CLIENT_ID=your-client-id
CODEFORGE_OIDC_CLIENT_SECRET=your-client-secret
CODEFORGE_OIDC_REDIRECT_URI=https://staging.yourdomain.com/auth/callback
