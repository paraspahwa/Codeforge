{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CodeForge Desktop",
  "version": "0.1.0",
  "identifier": "in.codeforge.desktop",
  "build": {
    "beforeDevCommand": "npm --workspace apps/desktop run dev",
    "beforeBuildCommand": "npm --workspace apps/desktop run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "CodeForge Desktop",
        "width": 1400,
        "height": 900,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; connect-src 'self' http://localhost:8000 http://127.0.0.1:8000 ws://localhost:8000 https: wss:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
