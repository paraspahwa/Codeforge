{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CodeForge Desktop",
  "version": "0.1.0",
  "identifier": "in.codeforge.desktop",
  "build": {
    "beforeDevCommand": "npm --workspace apps/desktop run dev",
    "beforeBuildCommand": "npm --workspace apps/desktop run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "CodeForge Desktop",
        "width": 1100,
        "height": 740,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
