{
  "name": "codeforge-vscode",
  "displayName": "CodeForge",
  "description": "CodeForge VS Code extension MVP",
  "version": "0.1.0",
  "private": true,
  "publisher": "codeforge",
  "engines": {
    "vscode": "^1.101.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./extension.js",
  "contributes": {
    "configuration": {
      "title": "CodeForge",
      "properties": {
        "codeforge.apiBaseUrl": {
          "type": "string",
          "default": "http://127.0.0.1:8000",
          "description": "CodeForge API base URL"
        },
        "codeforge.userId": {
          "type": "string",
          "default": "dev-user",
          "description": "Dev login user id"
        }
      }
    },
    "commands": [
      {
        "command": "codeforge.openPanel",
        "title": "CodeForge: Open Panel"
      },
      {
        "command": "codeforge.explainSelection",
        "title": "CodeForge: Explain Selection"
      },
      {
        "command": "codeforge.refactorSelection",
        "title": "CodeForge: Refactor Selection"
      },
      {
        "command": "codeforge.reviewDiff",
        "title": "CodeForge: Review Current File"
      },
      {
        "command": "codeforge.openProposalTarget",
        "title": "CodeForge: Open Proposed Target"
      },
      {
        "command": "codeforge.refreshProposalDiff",
        "title": "CodeForge: Refresh Proposal Git Diff"
      },
      {
        "command": "codeforge.runAgentLoop",
        "title": "CodeForge: Run Verify / Fix Loop"
      },
      {
        "command": "codeforge.openTeam",
        "title": "CodeForge: Open Team"
      },
      {
        "command": "codeforge.openCowork",
        "title": "CodeForge: Open Cowork"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "codeforge.reviewDiff",
          "group": "navigation@7",
          "when": "editorTextFocus"
        },
        {
          "command": "codeforge.openProposalTarget",
          "group": "navigation@8",
          "when": "editorTextFocus"
        },
        {
          "command": "codeforge.refreshProposalDiff",
          "group": "navigation@9",
          "when": "editorTextFocus"
        }
      ]
    }
  },
  "scripts": {
    "check": "node --check extension.js && node --check media/panel.js"
  }
}