{
  "name": "codeforge-vscode",
  "displayName": "CodeForge",
  "description": "CodeForge VS Code extension MVP",
  "version": "0.1.0",
  "private": true,
  "publisher": "codeforge",
  "engines": {
    "vscode": "^1.101.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codeforge.openPanel",
        "title": "CodeForge: Open Panel"
      },
      {
        "command": "codeforge.explainSelection",
        "title": "CodeForge: Explain Selection"
      },
      {
        "command": "codeforge.refactorSelection",
        "title": "CodeForge: Refactor Selection"
      },
      {
        "command": "codeforge.reviewDiff",
        "title": "CodeForge: Review Current File"
      },
      {
        "command": "codeforge.openProposalTarget",
        "title": "CodeForge: Open Proposed Target"
      },
      {
        "command": "codeforge.refreshProposalDiff",
        "title": "CodeForge: Refresh Proposal Git Diff"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "codeforge.reviewDiff",
          "group": "navigation@7",
          "when": "editorTextFocus"
        },
        {
          "command": "codeforge.openProposalTarget",
          "group": "navigation@8",
          "when": "editorTextFocus"
        },
        {
          "command": "codeforge.refreshProposalDiff",
          "group": "navigation@9",
          "when": "editorTextFocus"
        }
      ]
    }
  },
  "scripts": {
    "check": "node --check extension.js && node --check media/panel.js"
  }
}