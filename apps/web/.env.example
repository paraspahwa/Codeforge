# Web app environment (copy to apps/web/.env.local for local dev)
NEXT_PUBLIC_API_BASE=http://localhost:8000
CODEFORGE_PUBLIC_API_BASE=http://localhost:8000
CODEFORGE_DEV_LOGIN_SECRET=local-dev-login-secret

# Supabase Auth (optional — enables email/OAuth sign-in on /login)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
